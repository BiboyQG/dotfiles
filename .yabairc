#!/usr/bin/env sh

sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

if command -v sketchybar &>/dev/null; then
  # Check the display size (e.g., grab the resolution here)
  display_resolution=$(system_profiler SPDisplaysDataType | grep Resolution)
  if [[ "$display_resolution" == *"3024 x 1964"* ]]; then
    # 14-inch MacBook Pro
    yabai -m config top_padding 8
  elif [[ "$display_resolution" == *"3840 x 2160"* ]]; then
    # Mac Studio
    yabai -m config top_padding 40
  else
    yabai -m config top_padding 0
  fi
fi

# global settings
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse off
yabai -m config window_origin_display focused
yabai -m config window_placement second_child
yabai -m config window_shadow off
yabai -m config window_opacity off
yabai -m config window_opacity_duration 2000.0
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 0.85
yabai -m config insert_feedback_color 0xffd75f5f
yabai -m config split_ratio 0.50
yabai -m config auto_balance off
yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# general space settings
yabai -m config layout bsp
yabai -m config bottom_padding 0
yabai -m config left_padding 0
yabai -m config right_padding 0
yabai -m config window_gap 0

focus_window_in_space='target="$(yabai -m query --windows --space | jq -r '"'"'map(select(."has-ax-reference" and ."is-visible" and (."is-hidden" | not) and (."is-minimized" | not) and .role == "AXWindow" and (((.app == "zoom.us" or .app == "Microsoft Teams") and .subrole == "AXSystemDialog") | not))) | .[-1].id // empty'"'"')"; [ -n "$target" ] && yabai -m window --focus "$target"'

# focus a real window after active space changes
yabai -m signal --add event=space_changed action="$focus_window_in_space"

# focus a real window after active display changes
yabai -m signal --add event=display_changed action="$focus_window_in_space"

# focus another window in the active space after the focused window closes
yabai -m signal --add event=window_destroyed active=yes action="yabai -m query --windows --window >/dev/null 2>&1 && exit 0; $focus_window_in_space"

# focus window after application is terminated
yabai -m signal --add event=application_terminated action="yabai -m query --windows --window >/dev/null 2>&1 || $focus_window_in_space"

zoom_share_title='^(zoom share (toolbar|statusbar) window|zoom annotation entrypoint|Annotation - Zoom|zoom floating video window)$'
teams_share_title='^(Sharing Indicator|Sharing control bar \| Microsoft Teams|Meeting compact view \| .* \| Microsoft Teams)$'

# redirect focus away from sticky screen-sharing controls
yabai -m signal --add event=window_focused app="^zoom\.us$" title="$zoom_share_title" action="$focus_window_in_space"
yabai -m signal --add event=window_focused app="^Microsoft Teams$" title="$teams_share_title" action="$focus_window_in_space"

# Disable specific apps from being managed
yabai -m rule --add app="^(Raycast|TencentMeeting)$" manage=off
yabai -m rule --add app="^(.*zoom\.us.*)$" title="^(Zoom)$" manage=off
yabai -m rule --add app="^zoom\.us$" title="$zoom_share_title" manage=off mouse_follows_focus=off
yabai -m rule --add app="^Microsoft Teams$" title="$teams_share_title" manage=off mouse_follows_focus=off

echo "yabai configuration loaded.."
