# open kitty
cmd - return : /Applications/kitty.app/Contents/MacOS/kitty --single-instance -d "$HOME"

# open Arc browser
cmd + shift - return : osascript -e 'tell application "Arc" to make new window' -e 'tell application "Arc" to activate'

# Workspaces
alt - 1 : /opt/homebrew/bin/aerospace workspace 1
alt - 2 : /opt/homebrew/bin/aerospace workspace 2
alt - 3 : /opt/homebrew/bin/aerospace workspace 3
alt - 4 : /opt/homebrew/bin/aerospace workspace 4
alt - 5 : /opt/homebrew/bin/aerospace workspace 5
alt - 6 : /opt/homebrew/bin/aerospace workspace 6
alt - 7 : /opt/homebrew/bin/aerospace workspace 7
alt - 8 : /opt/homebrew/bin/aerospace workspace 8
alt - 9 : /opt/homebrew/bin/aerospace workspace 9
alt - 0 : /opt/homebrew/bin/aerospace workspace 10

# Navigation
alt - h : /opt/homebrew/bin/aerospace focus left
alt - j : /opt/homebrew/bin/aerospace focus down
alt - k : /opt/homebrew/bin/aerospace focus up
alt - l : /opt/homebrew/bin/aerospace focus right

# Moving windows
shift + alt - h : /opt/homebrew/bin/aerospace move left
shift + alt - j : /opt/homebrew/bin/aerospace move down
shift + alt - k : /opt/homebrew/bin/aerospace move up
shift + alt - l : /opt/homebrew/bin/aerospace move right

# Move focus container to workspace
shift + alt - m : window_id="$(/opt/homebrew/bin/aerospace list-windows --focused --format '%{window-id}')" && \
                  /opt/homebrew/bin/aerospace workspace-back-and-forth && \
                  workspace="$(/opt/homebrew/bin/aerospace list-workspaces --focused)" && \
                  /opt/homebrew/bin/aerospace move-node-to-workspace --window-id "$window_id" --focus-follows-window "$workspace" && \
                  /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - p : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window --wrap-around prev && \
                  /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - n : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window --wrap-around next && \
                  /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change

# Resize windows
lctrl + alt - h : /opt/homebrew/bin/aerospace resize width +50
lctrl + alt - j : /opt/homebrew/bin/aerospace resize height +50
lctrl + alt - k : /opt/homebrew/bin/aerospace resize height -50
lctrl + alt - l : /opt/homebrew/bin/aerospace resize width +50

# Equalize size of windows
lctrl + alt - e : /opt/homebrew/bin/aerospace balance-sizes

# Enable / Disable AeroSpace
lctrl + alt - g : /opt/homebrew/bin/aerospace enable toggle

# Layout
alt - r : /opt/homebrew/bin/aerospace layout horizontal vertical
shift + alt - r : /opt/homebrew/bin/aerospace flatten-workspace-tree

# Set root orientation
shift + alt - x : /opt/homebrew/bin/aerospace layout horizontal
shift + alt - y : /opt/homebrew/bin/aerospace layout vertical

# Set insertion point for focused container
shift + lctrl + alt - h : /opt/homebrew/bin/aerospace join-with left
shift + lctrl + alt - j : /opt/homebrew/bin/aerospace join-with down
shift + lctrl + alt - k : /opt/homebrew/bin/aerospace join-with up
shift + lctrl + alt - l : /opt/homebrew/bin/aerospace join-with right

# Float / Unfloat window
alt - z : /opt/homebrew/bin/aerospace layout floating tiling

# Reload AeroSpace
shift + lctrl + alt - r : \
    /usr/bin/env osascript <<< \
        "display notification \"Reloading AeroSpace\" with title \"AeroSpace\""; \
    /opt/homebrew/bin/aerospace reload-config --no-gui

# Toggle window fullscreen zoom
alt - f : /opt/homebrew/bin/aerospace fullscreen --no-outer-gaps

# Close focused window
alt - q : /opt/homebrew/bin/aerospace close && \
          /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change

# Toggle window split type
alt - e : /opt/homebrew/bin/aerospace layout horizontal vertical

# Focus first empty workspace
alt - n : workspace="$(/opt/homebrew/bin/aerospace list-workspaces --monitor focused --empty --format '%{workspace} %{workspace-is-focused}' | awk '$2 == "false" { print $1; exit }')" && \
          [ -n "$workspace" ] && \
          /opt/homebrew/bin/aerospace workspace "$workspace"

# Send window to a workspace and focus
shift + alt - 1 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 1 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 2 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 2 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 3 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 3 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 4 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 4 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 5 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 5 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 6 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 6 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 7 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 7 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 8 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 8 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 9 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 9 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
shift + alt - 0 : /opt/homebrew/bin/aerospace move-node-to-workspace --focus-follows-window 10 && /opt/homebrew/bin/sketchybar --trigger aerospace_workspace_change
